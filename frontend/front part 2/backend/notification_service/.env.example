# Notification Service Configuration

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shoulder_to_shoulder_db

# Redis
REDIS_URL=redis://localhost:6379/0

# NATS
NATS_URL=nats://localhost:4222

# Security
SECRET_KEY=super-secret-key-change-in-production-please-use-64-characters-minimum-!!!
ALGORITHM=HS256

# Service Communications
USER_SERVICE_URL=http://localhost:8000
GATEWAY_URL=http://localhost:8000

# Scheduler
SCHEDULER_INTERVAL_SECONDS=10

# Environment
ENVIRONMENT=development
PROJECT_NAME=Notification Service Плечом к плечу
API_V1_STR=/api/v1

# Logging
LOG_LEVEL=INFO
