# ============================================
# API конфигурация
# ============================================
# Скопируйте этот файл в .env и заполните значения

# URL сервисов (каждый микросервис на своём порту)
VITE_USER_API_URL=http://localhost:8000/api/v1
VITE_PLACES_API_URL=http://localhost:8004/api/v1
VITE_EVENTS_API_URL=http://localhost:8002/api/v1

# OSRM сервер (построение маршрутов)
# Можно использовать публичный или поднять свой
VITE_OSRM_BASE_URL=https://router.project-osrm.org

# ============================================
# Режимы работы
# ============================================

# Окружение: development | production
VITE_APP_ENV=development

# Включить подробные логи в консоли
VITE_DEBUG=true

# ============================================
# Примечание для разработчиков
# ============================================
# VITE_ — префикс обязателен, иначе Vite не подставит переменные в клиентский код
# Файл .env НЕ коммитится в git (добавлен в .gitignore)
# Файл .env.example коммитится и содержит шаблон
