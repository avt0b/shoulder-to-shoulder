  "frontend_integration": {
    "description": "Как использовать данные в фронете (Vue.js)",
    "example_code": `
// API клиент (src/services/api.js)
export const getSafeRoute = (startLat, startLng, endLat, endLng) => {
  return apiClient.get('/route/safe', {
    params: {
      start_lat: startLat,
      start_lng: startLng,
      end_lat: endLat,
      end_lng: endLng
    }
  })
};

// Компонент (RouteNavigator.vue)
const buildSafeRoute = async () => {
  try {
    const data = await getSafeRoute(
      startLat.value,
      startLng.value,
      endPlace.value.lat,
      endPlace.value.lng
    );
    
    // Рисуем маршант на карте
    drawRoute(data.safest_route.coordinates);
    
    // Показываем инфо
    routeInfo.value = {
      distance: data.safest_route.distance_m,
      riskScore: data.safest_route.risk_score,
      aiComment: data.ai_comment,
      alternatives: data.all_routes.length
    };
  } catch (err) {
    console.error('Ошибка маршрута:', err);
  }
};
    `
  },

  "response_fields": {
