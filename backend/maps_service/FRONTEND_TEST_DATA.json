  "vue_component_example": {
    "name": "RouteComparison.vue",
    "location": "frontend/app/src/components/RouteComparison.vue",
    "code": `
<template>
  <div class="route-comparison">
    <h2>Сравнение маршрутов</h2>
    
    <div class="route-card safest" v-if="safestRoute">
      <div class="header">
        <span class="badge safe">✓ РЕКОМЕНДУЕМЫЙ</span>
        <span class="risk-score" :class="'risk-' + getRiskLevel(safestRoute.risk_score)">
          Риск: {{ safestRoute.risk_score.toFixed(1) }}/10
        </span>
      </div>
      
      <div class="info">
        <div>📍 Расстояние: {{ (safestRoute.distance_m / 1000).toFixed(2) }} км</div>
        <div>⏱️ Время: ~{{ Math.ceil(safestRoute.distance_m / 80) }} минут</div>
        <div>🛣️ Тип дороги: {{ safestRoute.highway_type }}</div>
      </div>
      
      <div class="comment">{{ aiComment }}</div>
      
      <button @click="selectRoute(safestRoute)">Выбрать</button>
    </div>
    
    <div class="route-card shortest" v-if="shortestRoute">
      <div class="header">
        <span class="badge quick">⚡ БЫСТРАЯ</span>
        <span class="risk-score" :class="'risk-' + getRiskLevel(shortestRoute.risk_score)">
          Риск: {{ shortestRoute.risk_score.toFixed(1) }}/10
        </span>
      </div>
      
      <div class="info">
        <div>📍 Расстояние: {{ (shortestRoute.distance_m / 1000).toFixed(2) }} км</div>
        <div>⏱️ Время: ~{{ Math.ceil(shortestRoute.distance_m / 80) }} минут</div>
      </div>
      
      <button @click="selectRoute(shortestRoute)">Выбрать</button>
    </div>
    
    <div v-if="allRoutes.length > 2" class="alternatives">
      <p>{{ allRoutes.length - 2 }} альтернативный маршрут(ов) доступно</p>
    </div>
  </div>
</template>

<script setup>
import { ref } from 'vue'
import { getSafeRoute } from '@/services/api'

const safestRoute = ref(null)
const shortestRoute = ref(null)
const allRoutes = ref([])
const aiComment = ref('')

const getRiskLevel = (score) => {
  if (score < 2) return 'very-safe'
  if (score < 4) return 'safe'
  if (score < 6) return 'medium'
  return 'dangerous'
}

const findRoutes = async (startLat, startLng, endLat, endLng) => {
  try {
    const data = await getSafeRoute(startLat, startLng, endLat, endLng)
    
    safestRoute.value = data.safest_route
    shortestRoute.value = data.shortest_route
    allRoutes.value = data.all_routes
    aiComment.value = data.ai_comment
  } catch (err) {
    console.error('Ошибка:', err)
  }
}

const selectRoute = (route) => {
  // Отправить выбранный маршрут родителю или нарисовать на карте
  console.log('Выбран маршрут:', route)
}

defineExpose({ findRoutes })
</script>

