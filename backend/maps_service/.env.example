# Maps Service - Конфигурация

## Копируйте этот файл в `.env` и заполните значения

# Database Configuration
DATABASE_URL=postgresql+asyncpg://maps_user:maps_password@localhost:5432/maps_db

# Logging
DB_ECHO=False

# API Configuration
API_V1_PREFIX=/api/v1
APP_NAME=Maps Service
APP_VERSION=0.1.0

# Validation
MIN_LATITUDE=-90
MAX_LATITUDE=90
MIN_LONGITUDE=-180
MAX_LONGITUDE=180

# Maps
DEFAULT_ZOOM=14
SEARCH_RADIUS_KM=5.0
