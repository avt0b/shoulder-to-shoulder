PROJECT_ROOT=/shoulder-to-shoulder
APP_HOME=/shoulder-to-shoulder

ENVIRONMENT=development
TZ=Europe/Moscow
LOG_LEVEL=INFO
API_V1_STR=/api/v1

SECRET_KEY=CHANGE_ME_GENERATE_64_RANDOM_CHARS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=shoulder_to_shoulder_db
POSTGRES_PORT=5444
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/shoulder_to_shoulder_db
LOCAL_DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_POSTGRES_PASSWORD@localhost:5444/shoulder_to_shoulder_db

NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_URL=nats://nats:4222

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MEDIA_BUCKET=dev-media
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_PUBLIC_URL=http://localhost:8005/api/v1/media
MAX_FILE_SIZE=10485760
ALLOWED_CONTENT_TYPES_STR=image/jpeg,image/png,image/webp,image/svg+xml
ALLOWED_PURPOSES_STR=avatar,event,spot,badge

USER_SERVICE_PROJECT_NAME=User Service Плечом к плечу
USER_SERVICE_PORT=8000
USER_SERVICE_URL=http://user_service:8000

NOTIFICATION_SERVICE_PROJECT_NAME=Notification Service Плечом к плечу
NOTIFICATION_SERVICE_PORT=8001
NOTIFICATION_SERVICE_URL=http://notification_service:8001

EVENT_SERVICE_PROJECT_NAME=Event Service Плечом к плечу
EVENT_SERVICE_PORT=8002
EVENT_SERVICE_URL=http://event_service:8002

ADMIN_SERVICE_PROJECT_NAME=Admin Service Плечом к плечу
ADMIN_SERVICE_PORT=8003
ADMIN_SERVICE_URL=http://admin_service:8003

MEDIA_SERVICE_PROJECT_NAME=Media Service Плечом к плечу
MEDIA_SERVICE_PORT=8006
MEDIA_SERVICE_URL=http://media_service:8006

GATEWAY_SERVICE_PROJECT_NAME=Gateway Service Плечом к плечу
GATEWAY_SERVICE_PORT=8005
GATEWAY_URL=http://gateway_service:8005

MAPS_SERVICE_PORT=8004
MAPS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8005/api/v1
VITE_APP_ENV=development
VITE_DEBUG=false

SCHEDULER_INTERVAL_SECONDS=10


