# Absolute project paths
PROJECT_ROOT=/shoulder-to-shoulder
APP_HOME=/shoulder-to-shoulder

# Common environment
ENVIRONMENT=development
TZ=Europe/Moscow
LOG_LEVEL=INFO
API_V1_STR=/api/v1

# Security
SECRET_KEY=super-secret-key-change-in-production-please-use-64-characters-minimum-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shoulder_to_shoulder_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/shoulder_to_shoulder_db

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# NATS
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_URL=nats://nats:4222

# MinIO / Media
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MEDIA_BUCKET=dev-media
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_PUBLIC_URL=http://93.183.71.160:8006
MAX_FILE_SIZE=10485760
ALLOWED_CONTENT_TYPES_STR=image/jpeg,image/png,image/webp
ALLOWED_PURPOSES_STR=avatar,event,spot,badge

# Service names and ports
USER_SERVICE_PROJECT_NAME=User Service Плечом к плечу
USER_SERVICE_PORT=8000
USER_SERVICE_URL=http://user_service:8000

NOTIFICATION_SERVICE_PROJECT_NAME=Notification Service Плечом к плечу
NOTIFICATION_SERVICE_PORT=8001
NOTIFICATION_SERVICE_URL=http://notification_service:8001

EVENT_SERVICE_PROJECT_NAME=Event Service Плечом к плечу
EVENT_SERVICE_PORT=8002
EVENT_SERVICE_URL=http://event_service:8002

ADMIN_SERVICE_PROJECT_NAME=Admin Service Плечом к плечу
ADMIN_SERVICE_PORT=8003
ADMIN_SERVICE_URL=http://admin_service:8003

MEDIA_SERVICE_PROJECT_NAME=Media Service Плечом к плечу
MEDIA_SERVICE_PORT=8006
MEDIA_SERVICE_URL=http://media_service:8006

MAPS_SERVICE_PORT=8004
MAPS_ALLOWED_ORIGINS=["http://93.183.71.160:3000"]

FRONTEND_PORT=3000
VITE_API_BASE_URL=http://93.183.71.160:8000
VITE_APP_ENV=development
VITE_DEBUG=true

# Cross-service config
GATEWAY_URL=http://user_service:8000
SCHEDULER_INTERVAL_SECONDS=10

# Bootstrap


FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123
