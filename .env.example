# Environment Configuration
ENVIRONMENT=development

# Project Settings
PROJECT_NAME=Плечом к плечу

# API Configuration
API_V1_STR=/api/v1

# Authentication & Security
SECRET_KEY=super-secret-key-change-in-production-please-use-64-characters-minimum-!!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/shoulder_to_shoulder_db
# For SberCloud Managed PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname?ssl=require

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# NATS Broker Configuration
NATS_URL=nats://nats:4222

# User Service Configuration
USER_SERVICE_HOST=user_service
USER_SERVICE_PORT=8000
USER_SERVICE_URL=http://user_service:8000

# Notification Service Configuration
NOTIFICATION_SERVICE_HOST=notification_service
NOTIFICATION_SERVICE_PORT=8001
NOTIFICATION_SERVICE_URL=http://notification_service:8001

# Event Service Configuration
EVENT_SERVICE_HOST=event_service
EVENT_SERVICE_PORT=8002
EVENT_SERVICE_URL=http://event_service:8002

# Admin Service Configuration
ADMIN_SERVICE_HOST=admin_service
ADMIN_SERVICE_PORT=8003
ADMIN_SERVICE_URL=http://admin_service:8003

# Frontend Configuration
FRONTEND_HOST=frontend
FRONTEND_PORT=3000

# Initial Superuser
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123

# Logging
LOG_LEVEL=INFO

# Docker Configuration
PYTHONUNBUFFERED=1
