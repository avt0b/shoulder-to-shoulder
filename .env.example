# ============================================
# MICROSERVICES CONFIGURATION
# ============================================

# Environment
ENVIRONMENT=development
PROJECT_NAME=Плечом к плечу

# API Configuration
API_V1_STR=/api/v1

# ============================================
# SECURITY
# ============================================

# Secret key for JWT (CHANGE IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=super-secret-key-change-in-production-please-use-64-characters-minimum-!!!

# JWT Token expiration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# DATABASE
# ============================================

# PostgreSQL Connection (all services share one database)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/shoulder_to_shoulder_db

# For production with managed PostgreSQL (e.g., Yandex Cloud):
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname?ssl=require

# ============================================
# CACHE
# ============================================

# Redis Connection
REDIS_URL=redis://redis:6379/0

# ============================================
# MESSAGE BROKER
# ============================================

# NATS Message Broker (JetStream enabled)
NATS_URL=nats://nats:4222

# ============================================
# MICROSERVICES ADDRESSES
# ============================================

# User Service
USER_SERVICE_HOST=user_service
USER_SERVICE_PORT=8000
USER_SERVICE_URL=http://user_service:8000

# Notification Service
NOTIFICATION_SERVICE_HOST=notification_service
NOTIFICATION_SERVICE_PORT=8001
NOTIFICATION_SERVICE_URL=http://notification_service:8001

# Event Service
EVENT_SERVICE_HOST=event_service
EVENT_SERVICE_PORT=8002
EVENT_SERVICE_URL=http://event_service:8002

# Admin Service
ADMIN_SERVICE_HOST=admin_service
ADMIN_SERVICE_PORT=8003
ADMIN_SERVICE_URL=http://admin_service:8003

# Maps Service
MAPS_SERVICE_HOST=maps_service
MAPS_SERVICE_PORT=8004
MAPS_SERVICE_URL=http://maps_service:8004

# Frontend
FRONTEND_HOST=frontend
FRONTEND_PORT=3000

# ============================================
# INITIAL DATA
# ============================================

# First superuser credentials
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO

# ============================================
# DOCKER
# ============================================

PYTHONUNBUFFERED=1
PYTHONPATH=/app

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Swagger/OpenAPI UI
OPENAPI_URL=/openapi.json
DOCS_URL=/docs
REDOC_URL=/redoc

